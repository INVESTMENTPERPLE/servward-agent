# ── Configuración del broker Servward en Linux ──────────────────────────
# Copia este archivo a /etc/ntfy/ntfy.env y rellénalo. Protégelo: chmod 600.
#
# IMPORTANTE: usa el MISMO token que ya usa tu Mac (start_server.sh / agent),
# o genera uno nuevo y actualízalo también en el Mac y en la app.

# Token bearer compartido (mismo en broker, agente y app)
NTFY_TOKEN=PEGA_AQUI_TU_TOKEN

# Escuchar SOLO en localhost: Cloudflare Tunnel termina el TLS y reenvía aquí.
NTFY_BIND=127.0.0.1
NTFY_PORT=2586

# Modo HTTP (sin certs locales): dejamos rutas inexistentes a propósito,
# para que server.py arranque en texto plano detrás del túnel.
NTFY_CERT=/dev/null/nocert
NTFY_KEY=/dev/null/nokey
